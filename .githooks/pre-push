#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Git passes ref update lines to pre-push via stdin. Our checks do not use
# them, and letting child test processes inherit that stdin can make shell-based
# tests accidentally execute ref names as commands.
exec </dev/null

echo "[pre-push] Skipping local push-time checks for this repository."
echo "[pre-push] GitHub Actions is the source of truth for push validation."
echo "[pre-push] Run 'pnpm run check:prepush' manually when you want the full suite locally."
